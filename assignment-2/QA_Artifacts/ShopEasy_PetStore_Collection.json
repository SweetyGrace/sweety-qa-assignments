          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user/login?username=&password=", "host": ["{{baseUrl}}"], "path": ["user", "login"], "query": [{ "key": "username", "value": "" }, { "key": "password", "value": "" }] }
          }
        },
        {
          "name": "TC-11 Positive — GET /user/{username}",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
            "pm.test('Response time < 3000ms', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });",
