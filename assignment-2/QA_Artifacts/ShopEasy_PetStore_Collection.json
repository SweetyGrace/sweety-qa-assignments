          ], "type": "text/javascript" } }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 101010,\n  \"name\": \"BuddyQA-Updated\",\n  \"status\": \"sold\",\n  \"photoUrls\": [\"https://example.com/dog.jpg\"]\n}" },
            "url": { "raw": "{{baseUrl}}/pet", "host": ["{{baseUrl}}"], "path": ["pet"] }
