            "body": { "mode": "raw", "raw": "{\n  \"id\": 101010,\n  \"name\": \"BuddyQA\",\n  \"status\": \"available\",\n  \"category\": { \"id\": 1, \"name\": \"Dogs\" },\n  \"photoUrls\": [\"https://example.com/dog.jpg\"],\n  \"tags\": [{ \"id\": 1, \"name\": \"qa-test\" }]\n}" },
