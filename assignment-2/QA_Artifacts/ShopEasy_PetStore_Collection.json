      "name": "User Module",
      "item": [
        {
          "name": "TC-09 Positive — POST /user Create User",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
            "pm.test('Response time < 3000ms', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });",
            "var jsonData = pm.response.json();",
            "pm.test('User created with correct message', function () { pm.expect(jsonData.message).to.eql('9001'); });"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": 9001,\n  \"username\": \"testuser_qa\",\n  \"firstName\": \"QA\",\n  \"lastName\": \"Tester\",\n  \"email\": \"qa@shopeasy.com\",\n  \"password\": \"Test@1234\",\n  \"phone\": \"9876543210\",\n  \"userStatus\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] }
          }
        },
        {
          "name": "TC-09 Negative — POST /user Empty Body",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status code is 400 or 405', function () { pm.expect(pm.response.code).to.be.oneOf([400, 405]); });",
            "pm.test('Response time < 3000ms', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] }
          }
        },
        {
          "name": "TC-10 Positive — GET /user/login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
            "pm.test('Response time < 3000ms', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });",
            "var jsonData = pm.response.json();",
            "pm.test('Response contains message', function () { pm.expect(jsonData).to.have.property('message'); });"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/user/login?username={{username}}&password={{password}}", "host": ["{{baseUrl}}"], "path": ["user", "login"], "query": [{ "key": "username", "value": "{{username}}" }, { "key": "password", "value": "{{password}}" }] }
          }
        },
        {
          "name": "TC-10 Negative — GET /user/login Empty Credentials",
          "event": [{ "listen": "test", "script": { "exec": [
